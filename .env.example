# Chirpy environment — single checklist of every variable the app/gate/sync use.
# Copy what you need to .env.local (browser/build), and set server vars in your host
# (Vercel project env, or selfhost/gate.env). NEVER commit real values — .env* is gitignored.

# ─── Browser / build (VITE_*, inlined at build time) ──────────────────────────────────

# Transport: "xmtp" for real encrypted DMs + MLS rooms; anything else = offline mock (default).
VITE_TRANSPORT=mock

# XMTP network: "dev" or "production" (default production).
VITE_XMTP_ENV=production

# WalletConnect v2 project id (injected wallets like MetaMask work without it).
VITE_WALLETCONNECT_PROJECT_ID=

# Browser RPC for ENS name/avatar reads. Use a DOMAIN-ALLOWLISTED key — it ships to the client.
VITE_MAINNET_RPC_URL=

# Gatekeeper bot address — MUST equal the address of XMTP_GATEKEEPER_PRIVATE_KEY (below).
# Used when creating gated rooms so the bot is added as super-admin (so it can admit joiners).
VITE_GATEKEEPER_ADDRESS=

# Optional web-deployment metadata surfaced by /api/health.
CHIRPY_BASE_URL=
CHIRPY_RELEASE_CHANNEL=local

# Recommended when production room joins use a self-hosted gate. Lets /api/health report the
# supported external-gate topology instead of treating missing web-side gatekeeper secrets as a blocker.
CHIRPY_EXTERNAL_GATE_URL=

# ─── Server: gate + sync (Vercel env or selfhost/gate.env — NEVER prefix these with VITE_) ──

# Gatekeeper bot EOA private key (0x-hex). Generate: node selfhost/gen-gatekeeper-key.mjs
# NOTE: @xmtp/node-sdk's native bindings do NOT run on Vercel serverless — run the gate in a
# container/VM (see selfhost/) and point each org's OrgConfig.gateUrl at it.
XMTP_GATEKEEPER_PRIVATE_KEY=

# Unrestricted SERVER RPC for on-chain gate reads (token/Safe/ENS). NOT a browser-allowlisted key.
MAINNET_RPC_URL=

# KV (Upstash / Vercel) for encrypted cross-device sync (api/usersync.js).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are accepted as fallbacks.

# Optional per-process fixed-window request limit shared by the server handlers.
# Defaults to 60 requests per 60,000 ms per client address.
CHIRPY_RATE_LIMIT_MAX=60
CHIRPY_RATE_LIMIT_WINDOW_MS=60000
