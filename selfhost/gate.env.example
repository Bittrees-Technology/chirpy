# Gate service environment. Copy to gate.env (the installer writes this for you).

# Public domain the gate is served at (used for nginx/SSL + CORS).
GATE_DOMAIN=gate.example.org

# Port the gate service listens on (behind nginx).
GATE_PORT=8788

# Unrestricted mainnet RPC for on-chain reads (token/Safe/ENS). Do NOT use a
# domain-allowlisted browser key here — a server has no browser origin.
MAINNET_RPC_URL=

# KV (Redis) for the roles / rooms / moderation registry.
KV_REST_API_URL=http://redis:6379
KV_REST_API_TOKEN=

# Org namespace this gate serves (matches OrgConfig.namespace).
GATE_NAMESPACE=acme
