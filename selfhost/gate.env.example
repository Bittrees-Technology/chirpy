# Self-hosted Chirpy gate environment. Copy to gate.env (the installer writes this for you).

# Public domain the gate is served at (used for your reverse proxy / TLS).
GATE_DOMAIN=gate.example.org

# Port the gate listens on (behind your reverse proxy).
GATE_PORT=8788

# CORS allow-origin: the exact origin of your Chirpy web app (the browser that POSTs joins).
# Use the real origin in production rather than "*".
GATE_ALLOW_ORIGIN=https://chirpy.example.org

# The gatekeeper bot's EOA private key (0x-hex). This wallet must be added as a super-admin
# of every gated room it manages. Generate one with:
#   node selfhost/gen-gatekeeper-key.mjs
XMTP_GATEKEEPER_PRIVATE_KEY=

# Unrestricted mainnet RPC for on-chain gate reads (token / Safe / ENS). Do NOT use a
# domain-allowlisted browser key here — a server has no browser origin.
MAINNET_RPC_URL=

# Optional per-process fixed-window request limit for /api/room-join.
# Defaults to 60 requests per 60,000 ms per client address.
CHIRPY_RATE_LIMIT_MAX=60
CHIRPY_RATE_LIMIT_WINDOW_MS=60000
