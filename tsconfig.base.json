{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@app/core": ["packages/core/src/index.ts"],
      "@app/core/*": ["packages/core/src/*"],
      "@app/transport": ["packages/transport/src/index.ts"],
      "@app/transport/*": ["packages/transport/src/*"]
    }
  },
  "include": ["packages/*/src", "apps/*/src"]
}
