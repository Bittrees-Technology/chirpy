{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parley",
  "version": "0.1.0",
  "identifier": "org.bittrees.parley",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Parley",
        "width": 1100,
        "height": 740,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5NUYxQkE5MjM3NUExNzEKUldSeG9YVWpxUnRmU1F4b0hmY1lrR2xOK0dCUHNTbFZtcThiZUo4VjhxdUFYRktjNnpCRGQzQVAK",
      "endpoints": [
        "https://github.com/Bittrees-Technology/chat/releases/latest/download/latest.json"
      ]
    }
  }
}
