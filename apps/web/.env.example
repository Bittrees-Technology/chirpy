# Chirpy — environment template.
# Copy to .env.local for local dev; set the same keys in the Vercel project for production.
# Browser-exposed values MUST be prefixed VITE_. Secrets without VITE_ stay server-only.

# --- Wallet / login ---
# WalletConnect (Reown) project id — required for WalletConnect login. Injected
# wallets (MetaMask) work without it. Allowlist the deploy domain on the key.
VITE_WALLETCONNECT_PROJECT_ID=

# --- RPC / ENS (Alchemy) ---
# Browser RPC for ENS name + avatar resolution (domain-restrict this key on Alchemy).
VITE_MAINNET_RPC_URL=
# Optional explicit Alchemy key if you prefer building the URL in-app.
VITE_ALCHEMY_API_KEY=

# --- Server-side (Vercel env, NOT exposed to the browser) ---
# Unrestricted mainnet RPC for the serverless token-gate + server ENS/Safe reads.
# Do NOT reuse the domain-allowlisted VITE_ key here — a serverless function has no
# browser origin and would get 403'd. Upload this in the Vercel dashboard / `vercel env`.
MAINNET_RPC_URL=

# --- Gated rooms backend (when XmtpTransport / Push is wired) ---
# Upstash KV for the roles/rooms/moderation registry + cross-device sync.
KV_REST_API_URL=
KV_REST_API_TOKEN=
