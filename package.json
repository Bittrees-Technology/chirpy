{
  "name": "chat-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @app/web dev",
    "build": "pnpm --filter @app/web build",
    "preview": "pnpm --filter @app/web preview",
    "rollout:proof": "node scripts/rollout-proof.mjs",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "typecheck:api": "tsc -p tsconfig.api.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --grep-invert @xmtp",
    "e2e:xmtp": "XMTP_E2E=1 VITE_TRANSPORT=xmtp VITE_XMTP_ENV=dev playwright test --grep @xmtp",
    "tauri": "pnpm --filter @app/web tauri"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "jsdom": "29.1.1",
    "typescript": "^5.6.3",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
